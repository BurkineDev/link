# =============================================================================
# LinkBoutik — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# ---- App --------------------------------------------------------------------
# Public base URL used for Stripe success/cancel redirects, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Supabase (required) ----------------------------------------------------
# Project URL + anon key are public (sent to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
# Service role key — SERVER ONLY, bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# ---- Stripe (required for card payments) ------------------------------------
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret for /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...
# Creator "Pro" subscription — price + optional launch coupon (optional)
STRIPE_PRO_PRICE_ID=price_...
STRIPE_COUPON_ID=

# ---- GeniusPay (Mobile Money — required for mobile money payments) ----------
GENIUSPAY_BASE_URL=https://api.geniuspay.example
GENIUSPAY_API_KEY=<geniuspay-api-key>
GENIUSPAY_API_SECRET=<geniuspay-api-secret>
# Signing secret for /api/webhooks/geniuspay
GENIUSPAY_WEBHOOK_SECRET=<geniuspay-webhook-secret>

# ---- Anthropic (required for the free AI tools under /api/outils/*) ----------
# Read automatically by the Anthropic SDK (`new Anthropic()`).
ANTHROPIC_API_KEY=sk-ant-...

# ---- Upstash Redis (rate limiting + global AI budget cap) -------------------
# Required in production for the distributed per-IP limits and the global daily
# ceiling on /api/outils/*. Without these, only an in-memory per-instance
# limiter applies (no budget cap). Provision via the Vercel Marketplace.
UPSTASH_REDIS_REST_URL=https://<name>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<upstash-rest-token>

# ---- WhatsApp Cloud API (optional — seller order notifications) -------------
# When unset, seller notifications are skipped (orders still work).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
